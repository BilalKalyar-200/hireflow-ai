# HireFlow AI — Backend Environment Variables
# Copy this file to backend/.env and fill in your values.
# NEVER commit the real .env file to GitHub.

# ── App Settings ──────────────────────────────────────────
APP_NAME=HireFlow AI
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ── Qwen Cloud API ────────────────────────────────────────
QWEN_API_KEY=your_qwen_api_key_here
QWEN_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Use qwen-flash or qwen-plus during development; qwen-max for final demo
QWEN_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3
# Set to true to skip real API calls and use mock responses (saves tokens)
MOCK_QWEN=false

# ── MongoDB Atlas ─────────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hireflow?retryWrites=true&w=majority
MONGODB_DB_NAME=hireflow

# ── Qdrant Vector DB ──────────────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_RESUMES=resume_embeddings
QDRANT_COLLECTION_JDS=jd_embeddings

# ── Gmail SMTP (App Password — no OAuth) ──────────────────
GMAIL_USER=hireflow-ai@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
GMAIL_FROM_NAME=HireFlow AI

# ── Google Calendar (Service Account — no OAuth) ──────────
GOOGLE_SERVICE_ACCOUNT_FILE=../credentials/google-service-account.json
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# ── Alibaba Cloud OSS ─────────────────────────────────────
OSS_ACCESS_KEY_ID=your_alibaba_access_key_id
OSS_ACCESS_KEY_SECRET=your_alibaba_access_key_secret
OSS_ENDPOINT=oss-ap-southeast-1.aliyuncs.com
OSS_BUCKET_NAME=hireflow-ai-resumes
OSS_REGION=ap-southeast-1

# ── Scoring Thresholds ────────────────────────────────────
SCORE_AUTO_SHORTLIST=75
SCORE_BORDERLINE_MIN=50
SCORE_AUTO_REJECT=49

# ── Pipeline Settings ─────────────────────────────────────
MAX_CONCURRENT_RESUMES=10
MAX_PDF_SIZE_MB=5
PIPELINE_RETRY_ATTEMPTS=2

# ── CORS (frontend URL) ───────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
