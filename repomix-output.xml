}

.tab.active {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
}

/* ── Kanban ── */
.kanban-scroll {
  overflow-x: auto;
  padding-bottom: 0.5rem;
}

.kanban-board {
  display: flex;
  gap: 0.85rem;
  min-width: max-content;
  padding: 0.25rem 0;
}

.kanban-column {
  width: 260px;
  flex-shrink: 0;
  background: var(--color-column-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-card);
  display: flex;
  flex-direction: column;
  max-height: 520px;
}

.kanban-column.empty-column {
  border-style: dashed;
  opacity: 0.85;
}

.column-header {
  padding: 0.75rem;
  border-bottom: 1px solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
}

.column-header-left {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.8rem;
  font-weight: 700;
}

.header-badge {
  padding: 0.2rem 0.55rem;
  border-radius: 999px;
  font-size: 0.72rem;
  font-weight: 700;
  color: #fff;
}

.header-badge.pulse {
  animation: pulse-badge 1.8s ease-in-out infinite;
}

@keyframes pulse-badge {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0.65;
  }
}

.column-count {
  background: var(--color-card);
  border: 1px solid var(--color-border);
  border-radius: 999px;
  padding: 0.1rem 0.5rem;
  font-size: 0.7rem;
  font-weight: 700;
}

.column-body {
  padding: 0.5rem;
  overflow-y: auto;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.column-empty {
  text-align: center;
  padding: 1.5rem 0.5rem;
  font-size: 0.75rem;
  color: var(--color-text-muted);
}

.candidate-card {
  background: var(--color-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-btn);
  padding: 0.75rem;
  cursor: pointer;
  transition: all 0.2s ease;
}

.candidate-card:hover {
  box-shadow: var(--shadow-hover);
  transform: translateY(-2px);
  border-color: var(--color-primary);
}

.candidate-card.selected {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.3);
}

.candidate-card .name {
  font-weight: 700;
  font-size: 0.88rem;
}

.candidate-card .stage-row {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.72rem;
  color: var(--color-text-muted);
  margin-top: 0.25rem;
}

.score-badge {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 0.15rem 0.5rem;
  border-radius: 999px;
  color: #fff;
  margin-top: 0.4rem;
}

.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.25rem;
  margin-top: 0.4rem;
}

.skill-tag {
  font-size: 0.65rem;
  padding: 0.1rem 0.4rem;
  border-radius: 4px;
  background: var(--color-column-bg);
  border: 1px solid var(--color-border);
  color: var(--color-text-muted);
}

/* Skeleton loading */
.skeleton-card {
  background: var(--color-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-btn);
  padding: 0.75rem;
  animation: skeleton-pulse 1.2s ease-in-out infinite;
}

.skeleton-line {
  height: 10px;
  background: var(--color-border);
  border-radius: 4px;
  margin-bottom: 0.4rem;
}

.skeleton-line.short {
  width: 60%;
}

@keyframes skeleton-pulse {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

/* Pipeline empty state */
.pipeline-empty {
  text-align: center;
  padding: 3rem 1.5rem;
  background: var(--color-card);
  border: 1px dashed var(--color-border);
  border-radius: var(--radius-card);
}

.pipeline-empty .emoji {
  font-size: 3rem;
  margin-bottom: 0.75rem;
}

.pipeline-empty h3 {
  margin: 0 0 0.5rem;
  font-size: 1.1rem;
}

.pipeline-empty p {
  margin: 0;
  color: var(--color-text-muted);
  font-size: 0.9rem;
  max-width: 400px;
  margin-inline: auto;
}

/* ── Drawer ── */
.drawer-overlay {
  position: fixed;
  inset: 0;
  background: var(--color-overlay);
  z-index: 300;
  animation: fade-in 0.2s ease;
}

.drawer {
  position: fixed;
  top: 0;
  right: 0;
  width: 480px;
  max-width: 100vw;
  height: 100vh;
  background: var(--color-card);
  border-left: 1px solid var(--color-border);
  z-index: 301;
  overflow-y: auto;
  animation: slide-in 0.28s ease;
  box-shadow: -8px 0 32px rgba(0, 0, 0, 0.15);
}

@keyframes slide-in {
  from {
    transform: translateX(100%);
  }
  to {
    transform: translateX(0);
  }
}

@keyframes fade-in {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.drawer-header {
  padding: 1.25rem;
  border-bottom: 1px solid var(--color-border);
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
  position: sticky;
  top: 0;
  background: var(--color-card);
  z-index: 1;
}

.drawer-close {
  width: 36px;
  height: 36px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-btn);
  background: transparent;
  cursor: pointer;
  font-size: 1.1rem;
  color: var(--color-text-muted);
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.drawer-close:hover {
  background: var(--color-column-bg);
  transform: translateY(-1px);
}

.drawer-body {
  padding: 1.25rem;
}

.score-ring-wrap {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  margin-bottom: 1.5rem;
}

.score-ring {
  width: 88px;
  height: 88px;
  flex-shrink: 0;
}

.score-ring-label {
  font-size: 1.75rem;
  font-weight: 800;
}

.progress-row {
  margin-bottom: 0.85rem;
}

.progress-row-label {
  display: flex;
  justify-content: space-between;
  font-size: 0.78rem;
  margin-bottom: 0.3rem;
  color: var(--color-text-muted);
}

.progress-row-bar {
  height: 8px;
  background: var(--color-column-bg);
  border-radius: 999px;
  overflow: hidden;
}

.progress-row-fill {
  height: 100%;
  border-radius: 999px;
  transition: width 0.4s ease;
}

.quote-block {
  background: var(--color-quote-bg);
  border-left: 4px solid var(--color-primary);
  padding: 0.85rem 1rem;
  border-radius: 0 var(--radius-btn) var(--radius-btn) 0;
  font-size: 0.85rem;
  font-style: italic;
  margin: 0;
}

.timeline {
  border-left: 2px solid var(--color-border);
  padding-left: 1rem;
  margin-top: 0.5rem;
}

.timeline-item {
  position: relative;
  padding-bottom: 1rem;
}

.timeline-item::before {
  content: "";
  position: absolute;
  left: -1.35rem;
  top: 0.25rem;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--color-primary);
}

.review-banner {
  background: rgba(217, 119, 6, 0.12);
  border: 1px solid var(--color-warning);
  border-radius: var(--radius-btn);
  padding: 1rem;
  margin-bottom: 1.25rem;
}

.review-banner h4 {
  margin: 0 0 0.5rem;
  color: var(--color-warning);
}

.pill-badge {
  display: inline-block;
  padding: 0.25rem 0.6rem;
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 600;
  background: var(--color-column-bg);
  border: 1px solid var(--color-border);
  margin: 0.2rem 0.2rem 0 0;
}

/* ── Audit log ── */
.audit-panel {
  background: var(--color-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-card);
  padding: 1.25rem;
  box-shadow: var(--shadow-card);
}

.audit-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-bottom: 1rem;
}

.filter-btn {
  padding: 0.35rem 0.7rem;
  border-radius: 999px;
  border: 1px solid var(--color-border);
  background: var(--color-column-bg);
  font-size: 0.75rem;
  font-weight: 600;
  cursor: pointer;
  color: var(--color-text-muted);
  transition: all 0.2s ease;
}

.filter-btn:hover {
  transform: translateY(-1px);
}

.filter-btn.active {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
}

.audit-timeline {
  max-height: 420px;
  overflow-y: auto;
}

.audit-item {
  display: flex;
  gap: 0.75rem;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--color-border);
}

.audit-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--color-primary);
  margin-top: 0.35rem;
  flex-shrink: 0;
}

.audit-content {
  flex: 1;
  min-width: 0;
}

.audit-action {
  font-weight: 700;
  font-size: 0.85rem;
}

.audit-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
  margin-top: 0.35rem;
  align-items: center;
}

.tool-badge {
  font-size: 0.65rem;
  padding: 0.1rem 0.45rem;
  border-radius: 4px;
  background: var(--color-column-bg);
  border: 1px solid var(--color-border);
}

.token-pill {
  font-size: 0.65rem;
  padding: 0.1rem 0.45rem;
  border-radius: 999px;
  background: rgba(37, 99, 235, 0.12);
  color: var(--color-primary);
  font-weight: 600;
}

.audit-time {
  font-size: 0.72rem;
  color: var(--color-text-muted);
}

.audit-expand {
  margin-top: 0.4rem;
  font-size: 0.78rem;
  color: var(--color-primary);
  cursor: pointer;
  font-weight: 600;
  background: none;
  border: none;
  padding: 0;
}

.audit-reasoning {
  margin-top: 0.5rem;
  font-size: 0.8rem;
  color: var(--color-text-muted);
  padding: 0.65rem;
  background: var(--color-column-bg);
  border-radius: var(--radius-btn);
}

/* ── Toasts ── */
.toast-container {
  position: fixed;
  top: 5rem;
  right: 1.25rem;
  z-index: 400;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  max-width: 360px;
}

.toast {
  display: flex;
  align-items: flex-start;
  gap: 0.65rem;
  padding: 0.85rem 1rem;
  border-radius: var(--radius-btn);
  box-shadow: var(--shadow-hover);
  animation: toast-in 0.3s ease;
  font-size: 0.85rem;
  color: #fff;
}

@keyframes toast-in {
  from {
    transform: translateX(120%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

.toast-success {
  background: var(--color-success);
}

.toast-error {
  background: var(--color-danger);
}

.toast-info {
  background: var(--color-primary);
}

.toast-icon {
  font-size: 1.1rem;
  flex-shrink: 0;
}

/* ── Misc ── */
.ws-status {
  font-size: 0.72rem;
  color: var(--color-text-muted);
  margin-top: 0.5rem;
  display: flex;
  align-items: center;
  gap: 0.35rem;
}

.ws-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--color-danger);
}

.ws-dot.live {
  background: var(--color-success);
}

.empty-state {
  text-align: center;
  padding: 2rem;
  color: var(--color-text-muted);
  font-size: 0.9rem;
}

.confirm-box {
  margin-top: 0.75rem;
  padding: 0.75rem;
  background: var(--color-column-bg);
  border-radius: var(--radius-btn);
  font-size: 0.82rem;
}

.confirm-actions {
  display: flex;
  gap: 0.5rem;
  margin-top: 0.5rem;
}

.section-title {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--color-text-muted);
  margin: 1.25rem 0 0.5rem;
  font-weight: 700;
}

@media (max-width: 1024px) {
  .kanban-column {
    width: 220px;
  }
}
