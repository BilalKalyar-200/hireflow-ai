    icon: "📊",
    pulse: false,
  },
  {
    id: "shortlisted",
    title: "Shortlisted",
    stages: [STAGES.SHORTLISTED, STAGES.EMAIL_SENT],
    color: COLORS.success,
    icon: "✅",
    pulse: false,
  },
  {
    id: "review",
